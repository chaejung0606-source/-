# ===== Supabase =====
# Supabase 대시보드 → Settings → API 에서 발급
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ⚠️ service_role 키 — 서버 전용. 절대 NEXT_PUBLIC_ 접두사 금지, 브라우저 노출 금지.
# 관리자(전체 조회·상태변경)·신청 저장 등 RLS 우회 작업을 서버 API에서만 사용.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 관리자 비밀번호 (운영 시 반드시 강력한 값으로 변경)
ADMIN_PASSWORD=change_me_strong_password

# mock 데이터 사용 여부 (true = 인메모리 mock, false = Supabase 사용)
NEXT_PUBLIC_USE_MOCK=true
